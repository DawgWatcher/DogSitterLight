# Google Calendar API — Service Account Credentials
# 1. Go to https://console.cloud.google.com
# 2. Create a project (or use an existing one)
# 3. Enable the Google Calendar API
# 4. Go to IAM & Admin > Service Accounts > Create Service Account
# 5. Create a JSON key for the service account and download it
# 6. Share your "Boarding & Daycare" calendar with the service account email
#    (the email looks like: your-service-account@your-project.iam.gserviceaccount.com)
#    Give it "Make changes to events" permission
# 7. Copy the values from the JSON key file into the fields below

GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=aecfc7cba07b4fde13757b22e13bb659b5b0189552a9e4b142ecad2ead7f8b71@group.calendar.google.com
